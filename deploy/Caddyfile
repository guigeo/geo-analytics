# Bloco de site do Geo Intelligence — APÊNDICE ao /etc/caddy/Caddyfile da VPS.
# A VPS já roda Caddy servindo outros sites; NÃO substitua o arquivo, apenas
# acrescente este bloco. Ver deploy/README.md (Fase 5).
#
# Layout na VPS:
#   /var/www/geo/                 -> build do frontend (index.html, assets/…)
#   /var/www/geo/tiles/*.pmtiles  -> tiles (enviados por rsync)

geo-intelligence.averisen.com {
	root * /var/www/geo
	file_server

	# Comprime tudo MENOS os tiles. PMTiles usa HTTP Range requests — comprimir
	# on-the-fly quebraria os ranges (e mandaria o arquivo inteiro por requisição).
	@notiles not path /tiles/*
	encode @notiles gzip zstd

	# Tiles: grandes e imutáveis — cache longo no navegador (range já funciona).
	@tiles path /tiles/*
	header @tiles Cache-Control "public, max-age=2592000, immutable"

	# Assets com hash no nome: cache agressivo.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
}
